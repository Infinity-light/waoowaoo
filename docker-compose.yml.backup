services:
  waoowaoo:
    build: .
    container_name: waoowaoo
    restart: unless-stopped


    ports:
      - "3000:3000"

    env_file:
      - path: .env
        required: false

    volumes:
      - waoowaoo-data:/app/./data/mysql


    networks:
      - app-network

networks:
  app-network:
    driver: bridge



volumes:
  waoowaoo-data:

